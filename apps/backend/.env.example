NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
SWAGGER_ENABLED=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Ruta Segura <no-reply@rutasegura.local>"

DB_HOST=localhost
DB_PORT=5434
DB_USER=ruta_segura
DB_PASSWORD=ruta_segura_pwd
DB_NAME=ruta_segura_rd
DB_SYNC=false
DB_MIGRATIONS_RUN=false
DB_LOGGING=false

JWT_SECRET=change_me_for_production
JWT_EXPIRES_IN=1d

# local keeps /uploads on disk. Use s3 for production with S3-compatible storage
# such as DigitalOcean Spaces, AWS S3, Cloudflare R2 or MinIO.
STORAGE_DRIVER=local
STORAGE_PUBLIC_BASE_URL=
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_FORCE_PATH_STYLE=false
STORAGE_S3_ACL=public-read

REALTIME_EVENTS_ENABLED=true
REDIS_URL=redis://localhost:6379

AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
IMAGE_MODERATION_ENABLED=true
IMAGE_MODERATION_REQUIRED=false
IMAGE_MODERATION_MODEL=omni-moderation-latest
IMAGE_MODERATION_SCORE_THRESHOLD=0.85
GOOGLE_MAPS_API_KEY=
OPENROUTESERVICE_API_KEY=

WEATHER_SYSTEM_USER_EMAIL=admin@demo.com
WEATHER_FLOOD_MONITOR_ENABLED=false
WEATHER_FLOOD_MONITOR_COUNTRIES=DO
WEATHER_FLOOD_MONITOR_INTERVAL_MINUTES=30
WEATHER_FLOOD_MONITOR_POINTS=
