{
  "name": "@ruta-segura/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "migration:show": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:show",
    "migration:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate src/database/migrations/AutoMigration",
    "format": "prettier --write \"src/**/*.ts\"",
    "check:prod-env": "node scripts/check-production-env.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.1",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "helmet": "8.1.0",
    "ioredis": "^5.8.2",
    "multer": "2.1.1",
    "nodemailer": "^8.0.7",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.29"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.3",
    "@types/jest": "30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "4.0.1",
    "eslint": "10.3.0",
    "jest": "30.4.2",
    "prettier": "3.3.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0 <27"
  }
}
